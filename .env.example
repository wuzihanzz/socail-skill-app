# DeepSeek API key — used by the backend proxy at /api/chat
# Get one from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Optional: port the server listens on (Zeabur/Vercel inject PORT automatically)
# PORT=3000

# Optional: comma-separated browser origins allowed to call /api/chat
# ALLOWED_ORIGINS=https://social.preview.aliyun-zeabur.cn,http://localhost:5173

# Optional: per-IP chat rate limit. Defaults: 12 requests per 60 seconds.
# CHAT_RATE_LIMIT_MAX=12
# CHAT_RATE_LIMIT_WINDOW_MS=60000
