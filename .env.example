# DeepSeek API key — used by the backend proxy at /api/chat
# Get one from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Zeabur PostgreSQL connection string. A PostgreSQL service in the same
# Zeabur project exposes this automatically; reference its connection variable.
DATABASE_URL=postgresql://postgres:password@postgresql.zeabur.internal:5432/postgres

# Long random string used to sign anonymous identity cookies.
# Keep this stable across deployments or users will receive a new identity.
COOKIE_SECRET=replace-with-at-least-32-random-characters

# Set false only for trusted private-network databases that do not use TLS.
# DATABASE_SSL=false

# Optional: port the server listens on (Zeabur/Vercel inject PORT automatically)
# PORT=3000

# Optional: comma-separated browser origins allowed to call /api/chat
# ALLOWED_ORIGINS=https://social.preview.aliyun-zeabur.cn,http://localhost:5173

# Optional: per-IP chat rate limit. Defaults: 12 requests per 60 seconds.
# CHAT_RATE_LIMIT_MAX=12
# CHAT_RATE_LIMIT_WINDOW_MS=60000

# Optional: maximum DeepSeek requests per anonymous user per day.
# CHAT_DAILY_LIMIT=200
# CHAT_DAILY_IP_LIMIT=300

# Optional salt used before storing daily IP usage hashes.
# Defaults to COOKIE_SECRET.
# IP_HASH_SALT=another-long-random-string
